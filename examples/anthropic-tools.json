[
  {
    "name": "calculate_route",
    "description": "Calculates the optimal route between two locations considering traffic, distance, and user preferences",
    "input_schema": {
      "type": "object",
      "properties": {
        "origin": {
          "type": "string",
          "description": "Starting location address or coordinates"
        },
        "destination": {
          "type": "string",
          "description": "Destination address or coordinates"
        },
        "mode": {
          "type": "string",
          "description": "Transportation mode",
          "enum": ["driving", "walking", "cycling", "transit"]
        },
        "avoidTolls": {
          "type": "boolean",
          "description": "Whether to avoid toll roads"
        }
      },
      "required": ["origin", "destination"]
    }
  }
]
